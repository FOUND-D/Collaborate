+/* Premium Loader Styles – Enhanced */
+.loader-container-custom {
+    display: flex;
+    flex-direction: column;
+    justify-content: center;
+    align-items: center;
+    height: 100%;
+    min-height: 200px;
+    width: 100%;
+    animation: fadeIn 0.3s ease both;
+}
+
+.spinner-ring {
+    width: 48px;
+    height: 48px;
+    border-radius: 50%;
+    border: 3px solid rgba(134, 134, 139, 0.15);
+    border-top-color: transparent;
+    animation: spin 0.8s linear infinite;
+    position: relative;
+}
+
+/* Outer glow ring */
+.spinner-ring::before {
+    content: '';
+    position: absolute;
+    inset: -4px;
+    border-radius: 50%;
+    border: 2px solid transparent;
+    border-top-color: rgba(10, 132, 255, 0.4);
+    animation: spin 1.2s linear infinite reverse;
+}
+
+/* Inner glow */
+.spinner-ring::after {
+    content: '';
+    position: absolute;
+    inset: 2px;
+    border-radius: 50%;
+    border: 2px solid transparent;
+    border-bottom-color: rgba(90, 200, 250, 0.3);
+    animation: spin 1.5s linear infinite;
+}
+
+.loader-text {
+    margin-top: 1.5rem;
+    color: #86868B;
+    font-size: 0.9rem;
+    font-weight: 500;
+    letter-spacing: 0.04em;
+    animation: pulse 2s ease-in-out infinite;
+}
